{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Client (Interface)",
            "type": "debugpy",
            "request": "launch",
            "program": "dsp/interface.py",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Server (MockUp/FastAPI)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "rrc.dsp.mockup_server:app"
            ],
            "jinja": true,
            "justMyCode": true,
        }
    ],
    "compounds": [
        {
        "name": "Mockup(Server)/Interface(Client)",
        "configurations": ["Python: Server (MockUp/FastAPI)", "Python: Client (Interface)"],
        "stopAll": true
        }
    ]
}